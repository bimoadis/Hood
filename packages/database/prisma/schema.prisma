datasource db {
  provider   = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  name       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  companions Companion[]
  accounts   Account[]
  sessions   Session[]
}

model Account {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider            String   // "google", "discord", "twitter"
  providerAccountId   String
  createdAt           DateTime @default(now())
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
}

model Companion {
  id           String            @id @default(uuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  species      String            // Fox, Owl, Deer, Wolf, etc.
  personality  String            // Brave, Wise, Curious, etc.
  evolutionLvl Int               @default(1)
  level        Int               @default(1)
  xp           Int               @default(0)
  
  // Vitals
  mood         String            @default("Happy")
  energy       Int               @default(100)
  health       Int               @default(100)
  hunger       Int               @default(0)
  happiness    Int               @default(50)
  
  // Stats
  strength     Int               @default(10)
  intelligence Int               @default(10)
  luck         Int               @default(10)
  friendship   Int               @default(0)

  memories     CompanionMemory[]
  inventory    Inventory[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model CompanionMemory {
  id          String    @id @default(uuid())
  companionId String
  companion   Companion @relation(fields: [companionId], references: [id], onDelete: Cascade)
  memoryKey   String
  memoryValue String
  embedding   Json?
  createdAt   DateTime  @default(now())
}

model Inventory {
  id           String    @id @default(uuid())
  companionId  String
  companion    Companion @relation(fields: [companionId], references: [id], onDelete: Cascade)
  itemName     String
  itemType     String    // e.g. "Weapon", "Cloak", "Potion"
  statModifier Int       @default(0)
  equipped     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
